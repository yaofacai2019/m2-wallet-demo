# M2 Wallet internal demo configuration
M2_WALLET_HOST=127.0.0.1
M2_WALLET_PORT=8787
M2_WALLET_API_KEY=replace-with-a-long-random-value

# Internal browser login passwords. Replace all values outside localhost.
M2_ADMIN_PASSWORD=replace-admin-password
M2_FINANCE_PASSWORD=replace-finance-password
M2_OPERATOR_PASSWORD=replace-operator-password
M2_VIEWER_PASSWORD=replace-viewer-password

# Keep simulation until test wallets and external signing are ready.
M2_BROADCAST_MODE=simulation
M2_PAYOUTS_ENABLED=true
M2_MAX_WITHDRAWAL_AMOUNT=10000
M2_DAILY_WITHDRAWAL_LIMIT=50000
M2_PROJECT_ENABLED=true
M2_PROJECT_CALLBACK_URL=
M2_MIN_CALLBACK_USDT=0
M2_MIN_CALLBACK_USDC=0
M2_WITHDRAWAL_VERIFICATION_ENABLED=false
M2_WITHDRAWAL_VERIFICATION_URL=
M2_ALLOWLIST_ENFORCED=false
M2_COLLECTIONS_ENABLED=true
M2_COLLECTION_THRESHOLD_USDT=100
M2_COLLECTION_THRESHOLD_USDC=100

# External wallet address derivation. Never place a private key here.
M2_ADDRESS_PROVIDER_URL=
M2_ADDRESS_PROVIDER_TOKEN=

# External signer/HSM boundary. Never place a seed phrase or raw private key here.
M2_SIGNER_URL=
M2_SIGNER_TOKEN=

# TRON USDT listener and broadcaster
M2_TRONGRID_URL=https://api.trongrid.io
M2_TRONGRID_API_KEY=
M2_TRON_USDT_CONTRACT=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t
M2_TRON_BROADCAST_URL=

# Polygon USDC listener and broadcaster
M2_POLYGON_RPC_URL=
M2_POLYGON_USDC_CONTRACT=0x3c499c542cEF5E3811e1192ce70d8cC03d5c3359
M2_POLYGON_CONFIRMATIONS=20
M2_POLYGON_LOOKBACK_BLOCKS=2000
M2_WITHDRAW_CONFIRMATIONS=20

# Signed merchant callbacks
M2_CALLBACK_SECRET=replace-with-a-different-long-random-value
M2_CALLBACK_ALLOWED_HOSTS=merchant.example.com
M2_CALLBACK_ALLOW_LOCAL_HTTP=false
